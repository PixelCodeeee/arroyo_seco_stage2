# ─────────────────────────────────────────
# Grafana Cloud (Prometheus Remote Write)
# ─────────────────────────────────────────
# Get these from: Grafana Cloud → Connections → Connect Data → Prometheus
GRAFANA_REMOTE_WRITE_URL=https://prometheus-xxx.grafana.net/api/prom/push
GRAFANA_CLOUD_USER=123456
GRAFANA_CLOUD_API_KEY=glc_xxxxxxxxxxxxxxxx

